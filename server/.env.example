# Database
MONGODB_URI=YOUR-MONGODB-STRING-WITH-DATABASE-MENTIONED

# Authentication
JWT_SECRET=ANY-SECURE-SECRET

# Encryption (32-byte hex string for AES-256)
ENCRYPTION_KEY=ANY-SECURE-KEY

# Server
PORT=8000

# Client URL for CORS
CLIENT_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Node Environment
NODE_ENV=development

# Firebase Configuration
FIREBASE_PROJECT_ID=YOUR-PROJECT-ID
FIREBASE_CLIENT_EMAIL=EMAIL-FROM-SERVICE-ACCOUNT-JSON
FIREBASE_PRIVATE_KEY=PRIVATE-KEY-FROM-SERVICE-ACCOUNT-JSON
